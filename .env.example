# =============================================
# Codex Agent 环境变量配置模板
# =============================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改值
# 3. 在使用前执行：source .env
# =============================================

# ---------------------------------------------
# 必需配置（所有模式都需要）
# ---------------------------------------------

# Agent 名称（用于选择 bot 账号）
# 可选值：main / kimi-agent / gpt-agent / glm-agent
OPENCLAW_AGENT_NAME="main"

# Telegram Chat ID（接收通知的账号）
# 获取方法：给 bot 发消息，查看 OpenClaw 日志中的 chat_id
OPENCLAW_AGENT_CHAT_ID="7936836901"

# 通知渠道
# 可选值：telegram / discord / whatsapp 等
OPENCLAW_AGENT_CHANNEL="telegram"

# ---------------------------------------------
# 可选配置（仅 Cron 巡检模式需要）
# ---------------------------------------------

# 项目状态文件路径
# 设置后启用 Cron 巡检模式
# OPENCLAW_PROJECT_STATE_FILE="/path/to/your/project/.codex-task-state.json"

# 任务 ID（用于状态追踪）
# 建议使用有意义的命名，如 TASK-001
# OPENCLAW_PROJECT_TASK_ID="TASK-001"

# 任务目录（任务相关文件存放位置）
# OPENCLAW_PROJECT_TASK_DIR="/path/to/your/project/tasks/TASK-001"

# ---------------------------------------------
# 使用示例
# ---------------------------------------------

# 示例 1：简单使用（仅通知）
# source .env
# codex exec --full-auto "任务描述"

# 示例 2：Cron 巡检模式
# 1. 取消注释上面的 OPENCLAW_PROJECT_* 变量
# 2. source .env
# 3. codex exec --full-auto "任务描述"
# 4. Cron 每 10 分钟自动巡检推进
